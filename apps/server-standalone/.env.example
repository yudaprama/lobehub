# Server Configuration
PORT=3210
NODE_ENV=production

# CORS Configuration
CORS_ORIGIN=*

# Database (if using database from main app)
DATABASE_URL=postgresql://user:password@localhost:5432/lobehub
DATABASE_DRIVER=postgresql

# Redis (if using redis)
REDIS_URL=redis://localhost:6379

# Authentication (if needed)
KEY_VAULTS_SECRET=your-secret-key-here
AUTH_SECRET=your-auth-secret-here

# S3 / File Storage (if needed)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# External Services (if needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Proxy Configuration (optional)
PROXY_URL=
ENABLE_PROXY_DNS=0

# QStash (optional - for task scheduling)
QSTASH_URL=
QSTASH_TOKEN=
APP_URL=

# Logging
DEBUG=lobe:*
