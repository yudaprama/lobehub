#!/usr/bin/env sh
# Post-commit hook: run type-check in the background. If it fails, open a
# GitHub issue automatically (one per distinct error set, deduped by hash).
#
# Requires: `gh` CLI authenticated (`gh auth status`).
# Skip with HUSKY=0 or SKIP_POST_TYPECHECK=1.

[ "${HUSKY-}" = "0" ] && exit 0
[ "${SKIP_POST_TYPECHECK-}" = "1" ] && exit 0

(
  set -e
  cd "$(git rev-parse --show-toplevel)" || exit 0

  # Give the user their terminal back before spawning heavy work.
  sleep 1

  TMPLOG=$(mktemp -t lobehub-typecheck.XXXXXX.log 2>/dev/null || mktemp)
  if bun run type-check > "$TMPLOG" 2>&1; then
    rm -f "$TMPLOG"
    exit 0
  fi

  ERROR_COUNT=$(grep -cE "error TS" "$TMPLOG" || echo 0)
  if [ "$ERROR_COUNT" -eq 0 ]; then
    rm -f "$TMPLOG"
    exit 0
  fi

  # Dedupe: hash the error lines (ignoring line numbers shifting). If an
  # open issue with the same hash exists, don't file a duplicate.
  HASH=$(grep -E "error TS" "$TMPLOG" \
    | sed -E 's/\([0-9]+,[0-9]+\)//' \
    | sort -u \
    | shasum \
    | cut -c1-12)

  BRANCH=$(git branch --show-current)
  COMMIT=$(git rev-parse --short HEAD)
  TITLE="tsgo type-check failed on ${BRANCH} (${ERROR_COUNT} errors, ${HASH})"

  if command -v gh >/dev/null 2>&1; then
    EXISTING=$(gh issue list --state open --search "\"${HASH}\" in:title" --json number --jq 'length' 2>/dev/null || echo 0)
    if [ "$EXISTING" -gt 0 ]; then
      rm -f "$TMPLOG"
      exit 0
    fi

    BODY=$(cat <<EOF
## Summary

\`bun run type-check\` (tsgo) reported **${ERROR_COUNT}** errors after commit \`${COMMIT}\` on branch \`${BRANCH}\`.

- Hash: \`${HASH}\`
- Commit: https://github.com/$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "lobehub/lobehub")/commit/${COMMIT}

## Errors

\`\`\`
$(head -100 "$TMPLOG")
\`\`\`

_Filed automatically by \`.githooks/post-commit\`. Disable with \`SKIP_POST_TYPECHECK=1 git commit ...\`._
EOF
)
    gh issue create --title "$TITLE" --body "$BODY" --label "type-check" 2>/dev/null \
      || gh issue create --title "$TITLE" --body "$BODY" 2>/dev/null \
      || echo "[post-commit] gh issue create failed — see $TMPLOG"
  else
    echo "[post-commit] tsgo failed with ${ERROR_COUNT} errors. Install \`gh\` to auto-file issues. Log: ${TMPLOG}"
    exit 0
  fi

  rm -f "$TMPLOG"
) >/dev/null 2>&1 </dev/null &

disown 2>/dev/null || true
exit 0
